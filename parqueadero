def cuadre():
    totalVehiculos=0
    sAutos=0
    sMotos=0
    for auto in autos:
        if auto[2]!=None:
            minutos=(datetime.strptime(auto[2], "%H%M") - datetime.strptime(auto[1], "%H%M")).seconds // 60
            totalVehiculos=totalVehiculos+minutos*tarifas[0]
            sAutos=sAutos+minutos*tarifas[0]
    for moto in motos:
        if moto[2]!=None:
            minutos=(datetime.strptime(moto[2], "%H%M") - datetime.strptime(moto[1], "%H%M")).seconds // 60
            totalVehiculos=totalVehiculos+minutos*tarifas[1]
            sMotos=sMotos+minutos*tarifas[1]
    print("La sumatoria de todos los vehiculos es: ", totalVehiculos)
    print("La sumatoria de los autos es: ",sAutos)
    print("La sumatoria de las motos es: ",sMotos)
