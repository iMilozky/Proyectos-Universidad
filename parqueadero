def ingresarvehiculo():
    global autos
    global motos
    global facturas
    facturas=facturas+1
    tipo=input("ingrese tipo de vehiculo, \"a\" para automovil y \"m\" para moto: ")
    if tipo=="a":
        placaAuto=input("Ingrese la placa del automovil (3 Letras seguidas de 3 numeros): ")
        for auto in autos:
            if auto[0]==placaAuto and auto[2]==None:
                print("la placa ya esta registrada") 
                return
        horaingreso=input("Digite la hora de ingreso(el formato de 24 horas hhmm): ")
        nombre=input("ingrese nombre del cliente: ")
        autos.append([placaAuto,horaingreso,None,nombre,facturas])
    elif tipo=="m":
        placaMoto=input("Ingrese la placa de la motocicleta (3 Letras seguidas de 2 numeros, seguidas de una letra): ")
        for moto in motos:
            if moto[0]==placaMoto and moto[2]==None:
                print("la placa ya esta registrada") 
                return
        horaingreso=input("Digite la hora de ingreso(el formato de 24 horas hhmm): ")
        nombre=input("ingrese nombre del cliente: ")
        motos.append([placaMoto,horaingreso,None,nombre,facturas])
